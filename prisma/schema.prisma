generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  userProviderId String
  provider       String
  username       String
  picture        String?
  password       String?
  role           Role     @default(CUSTOMER)
  isBlocked      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([provider, userProviderId])
  @@index([userProviderId, provider, email])
}

model Product {
  id             String @id @default(cuid())
  email          String @unique
  userProviderId String
  provider       String

  @@unique([provider, userProviderId])
  @@index([email])
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name, slug])
}

enum Role {
  ADMIN
  MANAGER
  SALER
  WRITER
  CUSTOMER
}
